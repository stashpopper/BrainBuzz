# ─── BrainBuzz Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Render: add these as Environment Variables in the Render dashboard.

# ── MongoDB (required by both services) ──────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGODB_DB_NAME=test

# ── Node.js Backend ───────────────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=<your-secure-random-jwt-secret>

# ── Cloudinary (required in production for PDF storage) ──────────────────────
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ── Mistral AI (required by Python service for embeddings) ────────────────────
MISTRAL_API_KEY=<your-mistral-api-key>

# ── Service URLs (set automatically in Docker; override if needed) ─────────────
# For docker-compose: PYTHON_SERVICE_URL=http://python-service:5002
# For unified container: PYTHON_SERVICE_URL=http://127.0.0.1:5002
PYTHON_SERVICE_URL=http://127.0.0.1:5002
